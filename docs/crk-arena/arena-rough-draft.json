          "type": "imageAppeared",
          "regionRef": "slot1_fight_region",
          "imageRef": "fight_button_available",
          "threshold": 0.82
        },
        "resource": "screenCapture",
        "timeoutSeconds": 2,
        "pollingSeconds": 0.5,
        "graphPosition": {
          "x": 780,
          "y": -160
        }
      },
      {
        "key": "fight_slot1",
