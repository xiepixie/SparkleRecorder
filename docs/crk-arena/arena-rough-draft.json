{
  "schema": "sparkle.workflow.draft.v1",
  "workflow": {
    "name": "CRK Arena Rough Draft",
    "tasks": [
      {
        "key": "enter_arena",
        "name": "进入竞技场",
        "type": "macro",
        "macroRef": {
          "name": "CRK - 进入竞技场"
        },
        "resource": "foregroundInput",
        "timeoutSeconds": 30,
        "graphPosition": {
          "x": 0,
          "y": 0
        }
      },
      {
        "key": "arena_list_ready",
        "name": "等待竞技场列表",
        "type": "condition",
        "condition": {
          "type": "imageAppeared",
          "regionRef": "arena_header_region",
          "imageRef": "arena_list_anchor",
          "threshold": 0.82
        },
        "resource": "screenCapture",
        "timeoutSeconds": 20,
        "pollingSeconds": 1,
        "graphPosition": {
          "x": 260,
          "y": 0
        }
      },
      {
        "key": "p1_slot1_blocked",
        "name": "第1页槽位1是否已打",
        "type": "condition",
        "condition": {
          "type": "imageAppeared",
          "regionRef": "slot1_blocked_region",
          "imageRef": "slot_blocked_badge",
          "threshold": 0.82
        },
        "resource": "screenCapture",
        "timeoutSeconds": 1.5,
        "pollingSeconds": 0.5,
        "graphPosition": {
          "x": 520,
          "y": -160
        }
      },
      {
        "key": "p1_slot1_available",
        "name": "第1页槽位1可挑战",
        "type": "condition",
