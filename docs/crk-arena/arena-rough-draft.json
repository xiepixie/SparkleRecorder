      {
        "key": "battle_result_ready",
        "name": "等待竞技场结算",
        "type": "condition",
        "condition": {
          "type": "imageAppeared",
          "regionRef": "result_region",
          "imageRef": "battle_result_anchor",
          "threshold": 0.82
