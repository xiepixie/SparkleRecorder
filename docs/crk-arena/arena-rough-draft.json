      {
        "key": "arena_done",
        "name": "竞技场流程完成",
        "type": "notification",
        "notification": {
          "title": "竞技场流程完成",
          "body": "已完成一次可挑战对手的战斗与领奖。",
          "severity": "info"
        },
        "graphPosition": {
          "x": 2080,
          "y": 360
        }
      },
      {
        "key": "no_target_found",
        "name": "未找到可挑战对手",
        "type": "notification",
        "notification": {
          "title": "未找到可挑战对手",
          "body": "两页扫描内没有发现可挑战按钮，请人工检查竞技场列表或刷新对手。",
          "severity": "warning"
        },
        "graphPosition": {
          "x": 2080,
          "y": 0
        }
      },
      {
        "key": "arena_attention",
        "name": "竞技场需要人工检查",
        "type": "notification",
        "notification": {
          "title": "竞技场需要人工检查",
          "body": "竞技场列表、翻页或战斗结算没有按预期出现。",
          "severity": "warning"
        },
        "graphPosition": {
          "x": 1560,
          "y": 520
        }
      }
