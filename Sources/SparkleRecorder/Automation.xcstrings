            "value": "This package references %d macros that are not in your local library. The workflows can still be imported, but those tasks will show as Missing macro until you import or recreate the macros."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此包引用了 %d 个当前宏库中不存在的宏。仍可导入工作流结构，但这些任务会显示为“宏缺失”，直到导入或重新创建对应宏。"
          }
        }
      }
    },
    "This removes \"%@\" from the workflow and removes dependencies attached to it.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This removes \"%@\" from the workflow and removes dependencies attached to it."
