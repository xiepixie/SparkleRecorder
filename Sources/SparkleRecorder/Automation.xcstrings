          "stringUnit": {
            "state": "translated",
            "value": "这会从工作流中移除“%@”，并移除与它相连的依赖。"
          }
        }
      }
    },
    "This removes task \"%@\" and %d dependent edges from the draft preview. Saved workflows are unchanged until you import.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This removes task \"%@\" and %d dependent edges from the draft preview. Saved workflows are unchanged until you import."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
