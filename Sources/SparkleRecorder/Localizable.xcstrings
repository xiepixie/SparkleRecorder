    "Draw Region records bounds on the display where you drag. Use this when the automation should stay tied to that monitor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Draw Region records bounds on the display where you drag. Use this when the automation should stay tied to that monitor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "框选区域会记录拖拽所在显示器的边界。适合需要固定在该显示器上的自动化。"
          }
        }
      }
    },
    "Draw Region records display-pixel bounds. Use this when the automation should inspect a fixed screen area.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Draw Region records display-pixel bounds. Use this when the automation should inspect a fixed screen area."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "框选区域会记录显示器像素边界。适合需要检查固定屏幕区域的自动化。"
          }
        }
      }
    },
    "Bounds are normalized to the selected display, which makes the region more tolerant of display size changes.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bounds are normalized to the selected display, which makes the region more tolerant of display size changes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "边界会按所选显示器归一化，更能适应显示器尺寸变化。"
          }
        }
      }
    },
    "Window context is available from %@. Draw Region can refresh it from the window under the pointer.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Window context is available from %@. Draw Region can refresh it from the window under the pointer."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可从 %@ 获取窗口上下文。框选区域也会根据指针下方窗口刷新上下文。"
          }
        }
      }
    },
    "No linked window context is available yet. Draw Region over the target window, or switch to display coordinates.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No linked window context is available yet. Draw Region over the target window, or switch to display coordinates."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还没有可用的关联窗口上下文。请在目标窗口上框选区域，或切换到显示器坐标。"
          }
        }
      }
    },
    "Content context is available from %@. Use this for OCR inside the app content area.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Content context is available from %@. Use this for OCR inside the app content area."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可从 %@ 获取内容上下文。适合在应用内容区域内做 OCR。"
          }
        }
      }
    },
    "Content bounds are not available yet. Draw Region over the app content, or switch to window/display coordinates.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Content bounds are not available yet. Draw Region over the app content, or switch to window/display coordinates."
