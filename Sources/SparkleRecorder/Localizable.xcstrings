    "Trigger recording, stop, and play from any app — without bringing SparkleRecorder to the front. You can change these in Preferences.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Trigger recording, stop, and play from any app — without bringing SparkleRecorder to the front. You can change these in Preferences."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可在任意 App 中录制、停止和播放，无需切到 SparkleRecorder。你可以在设置中修改这些快捷键。"
          }
        }
      }
    },
