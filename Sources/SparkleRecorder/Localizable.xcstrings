    "The little macro recorder for macOS that's quietly doing your repetitive work.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The little macro recorder for macOS that's quietly doing your repetitive work."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一款轻量的 macOS 宏录制工具，安静替你处理重复操作。"
          }
        }
      }
    },
