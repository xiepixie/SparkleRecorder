    "macOS requires explicit consent to capture and post input events. We never see what you type or click outside of recordings you initiate.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS requires explicit consent to capture and post input events. We never see what you type or click outside of recordings you initiate."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 需要明确授权，才能录制和发送输入事件。除你主动开始的录制外，我们不会查看你的输入或点击。"
          }
        }
      }
    },
