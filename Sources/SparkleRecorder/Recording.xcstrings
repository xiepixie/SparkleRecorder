    },
    "Select at least two recorded actions; wait gaps alone cannot create a behavior.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select at least two recorded actions; wait gaps alone cannot create a behavior."
