        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可回放宏事件仍会录制；缺失上下文会明确显示，而不是被猜测填充。"
          }
        }
      }
    },
    "Press Record to capture your first macro. SparkleRecorder will count down 3 seconds before it begins.": {
      "extractionState": "manual",
