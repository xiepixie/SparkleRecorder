    "Playable macro events still record; missing context is visible instead of being guessed.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Playable macro events still record; missing context is visible instead of being guessed."
