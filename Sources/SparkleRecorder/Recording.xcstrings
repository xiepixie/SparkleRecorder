            "state": "translated",
            "value": "Action recording"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "动作录制中"
          }
        }
      }
    },
    "As SparkleRecorder File…": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "As SparkleRecorder File…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "SparkleRecorder 文件…"
          }
        }
      }
    },
    "Capture anything": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Capture anything"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记录常用操作"
          }
        }
      }
    },
    "Click anywhere on the screen to pick coordinate": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click anywhere on the screen to pick coordinate"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在屏幕任意位置点击以选取坐标"
          }
        }
      }
    },
    "Click the menu-bar icon or this Dock icon to open the library. Press Record to capture your first macro — SparkleRecorder will count down %d seconds before it starts so you have time to switch to the right window.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click the menu-bar icon or this Dock icon to open the library. Press Record to capture your first macro — SparkleRecorder will count down %d seconds before it starts so you have time to switch to the right window."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点按菜单栏图标或 Dock 图标打开宏库。点按“录制”捕获第一个宏。开始前会倒计时 %d 秒，方便你切到目标窗口。"
          }
        }
      }
    },
    "Click the menu-bar icon or this Dock icon to open the library. Press Record to capture your first macro — recording starts immediately.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click the menu-bar icon or this Dock icon to open the library. Press Record to capture your first macro — recording starts immediately."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点按菜单栏图标或 Dock 图标打开宏库。点按“录制”即可捕获第一个宏，录制会立即开始。"
          }
        }
      }
    },
    "Click to Record": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click to Record"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击录入"
          }
        }
      }
    },
    "Click to record shortcut": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click to record shortcut"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击录入快捷键"
          }
        }
      }
    },
    "Drag to capture baseline": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag to capture baseline"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖动以捕获基准图"
          }
        }
      }
    },
    "Edits the captured key and modifiers while keeping the action timing in place.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Edits the captured key and modifiers while keeping the action timing in place."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "编辑捕获的按键和修饰键，同时保留该动作的时间位置。"
          }
        }
      }
    },
    "Grant Accessibility & Input Monitoring to record and replay.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grant Accessibility & Input Monitoring to record and replay."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "授予“辅助功能”和“输入监控”权限后即可录制和回放。"
          }
        }
      }
    },
    "Grant Accessibility, Input Monitoring & Screen Recording to record and replay.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grant Accessibility, Input Monitoring & Screen Recording to record and replay."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "授予“辅助功能”、“输入监控”和“屏幕录制”权限后即可录制和回放。"
          }
        }
      }
    },
    "Grant the required permissions before recording video, keyframes and playable macro events.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grant the required permissions before recording video, keyframes and playable macro events."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先授予必需权限，再录制视频、关键帧和可回放宏事件。"
          }
        }
      }
    },
    "Menu bar only hides the Dock icon — open SparkleRecorder from the menu-bar icon.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Menu bar only hides the Dock icon — open SparkleRecorder from the menu-bar icon."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏 Dock 图标后，可从菜单栏图标打开 SparkleRecorder。"
          }
        }
      }
    },
    "Menu bar only hides the Dock icon. Use the menu-bar icon to reopen SparkleRecorder.": {
      "extractionState": "manual",
      "generatesSymbol": false,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Menu bar only hides the Dock icon. Use the menu-bar icon to reopen SparkleRecorder."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“仅在菜单栏显示”会隐藏 Dock 图标。请使用菜单栏图标重新打开 SparkleRecorder。"
          }
        }
      }
    },
    "Move selected recorded actions earlier.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move selected recorded actions earlier."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将选中的录制动作提前。"
